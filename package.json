{
    "name": "scroll-snap-kit",
    "version": "2.0.0",
    "description": "Smooth scroll utilities and React hooks for modern web apps",
    "type": "module",
    "main": "./dist/index.cjs.js",
    "module": "./dist/index.esm.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.esm.js",
            "require": "./dist/index.cjs.js",
            "types": "./dist/index.d.ts"
        },
        "./utils": {
            "import": "./src/utils.js",
            "require": "./dist/index.cjs.js",
            "types": "./dist/index.d.ts"
        },
        "./hooks": {
            "import": "./src/hooks.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "src",
        "dist"
    ],
    "scripts": {
        "build": "node build.js",
        "prepublishOnly": "node build.js"
    },
    "keywords": [
        "scroll",
        "smooth-scroll",
        "parallax",
        "scroll-spy",
        "scroll-reveal",
        "infinite-scroll",
        "react-hooks",
        "viewport",
        "scroll-animation",
        "frontend",
        "ui"
    ],
    "author": "Fabian Faraz Farid",
    "license": "MIT",
    "peerDependencies": {
        "react": ">=16.8.0"
    },
    "peerDependenciesMeta": {
        "react": {
            "optional": true
        }
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/farazfarid/scroll-snap-kit.git"
    },
    "bugs": {
        "url": "https://github.com/farazfarid/scroll-snap-kit/issues"
    },
    "homepage": "https://farazfarid.github.io/scroll-snap-kit/"
}
